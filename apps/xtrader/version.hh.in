#pragma once

#include <seastar/core/sstring.hh>

namespace seastar::xtrader {

// ============================================================
// X-Trader Seastar 版本信息
// ============================================================

inline constexpr const char* version = "0.1.3";
inline constexpr const char* version_major = "0";
inline constexpr const char* version_minor = "1";
inline constexpr const char* version_patch = "3";

// ============================================================
// 构建信息（由 CMake 自动注入）
// ============================================================

inline constexpr const char* build_type = "@CMAKE_BUILD_TYPE@";
inline constexpr const char* git_commit = "@GIT_COMMIT_HASH@";
inline constexpr const char* git_branch = "@GIT_BRANCH@";
inline constexpr const char* build_timestamp = "@BUILD_TIMESTAMP@";

// ============================================================
// 功能特性开关
// ============================================================

inline constexpr bool enable_ctp_trading = true;
inline constexpr bool enable_redis_sync = true;
inline constexpr bool enable_historical_data = true;
inline constexpr bool enable_data_import = true;

// ============================================================
// 系统限制配置
// ============================================================

inline constexpr size_t max_instruments = 10000;
inline constexpr size_t max_positions = 1000;
inline constexpr unsigned default_account_shard = 1;
inline constexpr unsigned default_gateway_shard = 0;
inline constexpr size_t md_ring_buffer_capacity = 65536;
inline constexpr size_t trader_ring_buffer_capacity = 16384;
inline constexpr size_t max_drain_per_tick = 1024;
inline constexpr size_t max_drain_us = 500;

// ============================================================
// 应用程序信息
// ============================================================

inline constexpr const char* app_name = "xtrader";
inline constexpr const char* app_description = "Seastar-based quantitative trading engine";

// ============================================================
// 版本信息查询函数
// ============================================================

inline sstring get_version_string() {
    return sstring("xtrader ") + version;
}

inline sstring get_build_info() {
    return sstring("Build: ") + build_type + 
           " | Git: " + git_commit + 
           " | Branch: " + git_branch +
           " | Timestamp: " + build_timestamp;
}

inline void print_version() {
    std::cout << get_version_string() << std::endl;
    std::cout << get_build_info() << std::endl;
}

inline void print_version_detailed() {
    std::cout << "============================================" << std::endl;
    std::cout << "  X-Trader Seastar Trading Engine" << std::endl;
    std::cout << "============================================" << std::endl;
    std::cout << "Version:    " << version << std::endl;
    std::cout << "Major:      " << version_major << std::endl;
    std::cout << "Minor:      " << version_minor << std::endl;
    std::cout << "Patch:      " << version_patch << std::endl;
    std::cout << "----------------------------------------" << std::endl;
    std::cout << "Build Type: " << build_type << std::endl;
    std::cout << "Git Commit: " << git_commit << std::endl;
    std::cout << "Git Branch: " << git_branch << std::endl;
    std::cout << "Timestamp:  " << build_timestamp << std::endl;
    std::cout << "============================================" << std::endl;
    std::cout << "Features:" << std::endl;
    std::cout << "  CTP Trading:    " << (enable_ctp_trading ? "enabled" : "disabled") << std::endl;
    std::cout << "  Redis Sync:     " << (enable_redis_sync ? "enabled" : "disabled") << std::endl;
    std::cout << "  Historical Data: " << (enable_historical_data ? "enabled" : "disabled") << std::endl;
    std::cout << "  Data Import:    " << (enable_data_import ? "enabled" : "disabled") << std::endl;
    std::cout << "============================================" << std::endl;
}

} // namespace seastar::xtrader
